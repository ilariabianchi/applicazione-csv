#include <iostream>
#include <string>
#include <fstream>
using namespace std;

struct Location{
	double latitudine1;
	double longitudine1;
};
struct NumerazioneCivica{
	string classe;
	string descrizione;
	string numero;
	string subalterno;
	string cap;
	string istat;
	double latitudine;
	double longitudine;
	Location posto;	
};

/*
funzione carica dati: apre il file, legge il contenuto e caricarli nell'array di struct
parametri: array di struct, nome del file
-apro il file
-controllo esistenza
-lettura riga per riga
-estrarre i campi e metterli nella struct
*/
bool CaricaDati(NumerazioneCivica v[]){
	
    ifstream leggi("Comune_Bergamo_-_Numerazione_civica.csv");
	if(!leggi.is_open()){
		return false;
	}
	string riga, dati;
	//salto la prima riga perchè sono i titoli del documento
	getline(leggi, riga);
	int i=0;
	while(i<1000){
        getline(leggi, v[i].classe, ',');
        getline(leggi, v[i].descrizione, ',');
        getline(leggi, v[i].numero, ',');
        getline(leggi, v[i].subalterno, ',');
        getline(leggi, v[i].cap, ',');
        getline(leggi, v[i].istat, ',');
        //siccome i dati sono considerati stringhe, li prendo con il getline e poi con stod li trrasformo in double
        getline(leggi, dati, ',');
        v[i].latitudine=stod(dati);
        getline(leggi, dati, ',');
        v[i].longitudine=stod(dati);
        //latitudine e longitudine sono uguali sia per la struct NumerazioneCivica, sia per Location
        v[i].posto.latitudine1=v[i].latitudine;
        v[i].posto.longitudine1=v[i].longitudine;
        i++;
    }
    leggi.close();
    return true;
}

//funzione visualizza struct
string VisualizzaDati(NumerazioneCivica v[], int d){
	string s;
	for(int i=0; i<d; i++){
        s+=v[i].classe+"\t";
		s+=v[i].descrizione+"\t";
		s+=v[i].numero+"\t";
		s+=v[i].subalterno+"\t";
		s+=v[i].cap+"\t";
		s+=v[i].istat+"\t";
		s+=to_string(v[i].latitudine)+"\t";
		s+=to_string(v[i].longitudine)+"\t";	
    }
	return s;	
}

int main(){
	
	ifstream leggi("Comune_Bergamo_-_Numerazione_civica.csv");
	int opzione;
	NumerazioneCivica dati[10];
	int d=sizeof(dati)/sizeof(dati[0]);
	do{
		cout<<"1 - carica dati \n2 - visualizza dati \n0 - stop";
		cout<<"\ninserisci l'opzione: ";
		cin>>opzione;
		
		switch(opzione){
			case 1:{
				if(CaricaDati(dati)) {
                    cout<<"\ndati caricati correttamente\n"<<endl;
                }else{
                    cout<<"\nfile non aperto\n"<<endl;
                }
				break;
			}
			case 2:{
				cout<<VisualizzaDati(dati, d)<<endl;
				break;
			}	
		}
	}while(opzione!=0);


	return 0;
}
